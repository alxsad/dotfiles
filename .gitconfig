[user]
    name = Alex Davidovich
	email = alxsad@gmail.com
[color]
    ui = true
[alias]
    lg = log --graph --color --pretty=format:'%C(red)%h%C(reset) -%C(yellow)%d%C(reset) %s %C(green)(%cr) %C(bold blue)<%an>%C(reset)' --
    co = checkout
    cob = checkout -b
    ci = commit
    cim = commit -m
    cia = commit --amend -m
    p = push origin
    pp = push origin HEAD
    ppf = push origin HEAD --force
    u = pull
    uu = pull origin
    f = fetch -p
    rc = rebase --continue
    ra = rebase --abort
    br = branch
    bd = branch -d
    bD = branch -D
    st = status
    sts = status -sb
    aa = add .
    a = add
    df = diff --cached
    sl = stash list
    sp = stash pop
    sc = stash clear
    ss = stash
    v = describe --tags
    lst = log -1 HEAD --stat
    cl = config --list
    aliases = !git config --get-regexp 'alias.*' | colrm 1 6 | sed 's/[ ]/ = /'
[push]
    default = simple
    autoSetupRemote = true
    followTags = true
[merge]
    conflictstyle = zdiff3
[branch]
    sort = -committerdate
[rebase]
	stat = true
[http]
    sslVerify = true
[core]
    editor = vim
[init]
    defaultBranch = master
[tag]
    sort = version:refname
[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true
[fetch]
    prune = true
    pruneTags = true
    all = true
[column]
    ui = auto

[includeIf "gitdir:~/Projects/finteqhub/"]
    path = ~/.gitconfig-finteqhub
